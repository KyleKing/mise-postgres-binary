/// hk configuration for linting and pre-commit hooks
/// https://github.com/jdx/hk
amends "package://github.com/jdx/hk/releases/download/v1.49.0/hk@1.49.0#/Config.pkl"

import "package://github.com/jdx/hk/releases/download/v1.49.0/hk@1.49.0#/Builtins.pkl"

/// Global configuration
jobs = 0  // Auto-detect number of parallel jobs
fail_fast = true  // Abort on first failure for faster feedback
exclude = List("**/.luarocks/**", "**/luacov.*")

local linters = new Mapping<String, Step> {
    ["actionlint"] = Builtins.actionlint
    ["check-hk-version"] {
        glob = List("hk.pkl", "mise.lock")
        check = "scripts/check_hk_version.py"
        fix = "scripts/check_hk_version.py --fix"
    }
    ["byte-order-marker"] = Builtins.byte_order_marker
    ["check-added-large-files"] = Builtins.check_added_large_files
    ["check-executables-have-shebangs"] = Builtins.check_executables_have_shebangs
    ["check-lockfile-platforms"] {
        glob = List("mise.toml", "hk.pkl", "mise.lock")
        check = "scripts/check_lockfile_platforms.py"
        fix = "scripts/check_lockfile_platforms.py --fix"
    }
    ["check-merge-conflict"] = Builtins.check_merge_conflict
    ["check-symlinks"] = Builtins.check_symlinks
    ["detect-private-key"] = Builtins.detect_private_key
    ["jq"] = Builtins.jq
    ["mixed-line-ending"] = Builtins.mixed_line_ending
    ["newlines"] = Builtins.newlines
    ["ruff"] = Builtins.ruff
    ["selene"] = Builtins.selene
    ["stylua"] = Builtins.stylua
    ["toml-sort"] {
        glob = List("**/*.toml")
        check = "toml-sort --check {{ files }}"
        fix = "toml-sort --in-place {{ files }}"
    }
    ["trailing-whitespace"] = Builtins.trailing_whitespace
}

/// Hook definitions
hooks {
    ["pre-commit"] {
        fix = true  // Auto-fix issues when possible
        stash = "git"  // Stash unstaged changes during hook execution
        stage = true  // Auto-stage fixed files
        steps = linters
    }
    ["pre-push"] {
        steps = linters  // Run checks before pushing
    }
    ["fix"] {
        fix = true  // Manual fix command
        steps = linters
    }
    ["check"] {
        steps = linters  // Manual check command (read-only)
    }
}
